# ─────────────────────────────────────────────────────────────
# SUPABASE
# Copie esses valores do painel do Supabase:
# Project Settings → API → Project URL e anon/public key
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────
# SERVICE ROLE KEY (nunca expor no frontend — só usar no servidor)
# Project Settings → API → service_role key
# Necessária para operações admin (ex: buscar usuários pelo painel)
# ─────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────
# URL do site (usado em emails de confirmação do Supabase Auth)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seusite.vercel.app
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
